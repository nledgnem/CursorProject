# API keys (copy to .env and fill in; .env is gitignored)
# COINGECKO_API_KEY=your_coingecko_pro_key
# Optional: max days per market_chart/range call (Basic Pro ~2y cap; default 700)
# COINGECKO_MARKET_CHART_CHUNK_DAYS=700
# Rolling history depth from "today" for market_chart (Basic ~730d; Analyst+ set e.g. 4000)
# COINGECKO_MAX_HISTORY_LOOKBACK_DAYS=730
# COINGLASS_API_KEY=your_coinglass_key

# Telegram alerts (optional; used by scripts/live/live_data_fetcher.py)
# NOTE: You must message the bot (press Start) and add it to the target group/chat first,
# or Telegram will reject sends ("silent bot" behavior).
# TELEGRAM_BOT_TOKEN=123456789:AA...your_bot_token_here
# TELEGRAM_CHAT_ID=-1234567890123
