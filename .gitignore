# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments (large, machine-specific)
venv/
.venv/
env/
ENV/

# Python packaging / tooling
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Secrets and env (never commit)
.env
.env.local
.env.*
!.env.example
*_secret.json
*_keys.json
secrets/

# Streamlit (local secrets only; config.toml may be committed)
.streamlit/secrets.toml

# --- Local / runtime application state ---
# SQLite / DuckDB local databases (dashboard state, research DBs)
data/state/*.db
**/macro_state.db
*.duckdb

# Heartbeat last-success marker (see repo_paths.heartbeat_last_success_path)
**/heartbeat_last_pipeline_success.txt

# --- Logs (runtime; rotate / machine-specific) ---
logs/
!logs/.gitkeep

# --- Generated MSM pipeline report runs (timestamped folders) ---
reports/msm_funding_v0/20*/

# --- Scratch / one-off test outputs ---
data/panel_*.csv
data/panel_*.log
data/panel_*.txt
data/tmp_*.csv
single_coin_panel.csv

# --- Apathy Bleed runtime artifacts (do not commit) ---
# The trade book snapshot may be committed intentionally; do NOT ignore it here.
data/curated/data_lake/apathy_alert_log.csv
data/curated/data_lake/apathy_*_state.json

# Large zip bundles produced by pipelines (regenerate from source)
data/**/*.zip

# Temp directories
tmp/
temp/
scratch/
